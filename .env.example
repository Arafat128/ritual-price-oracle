# Your deployer wallet private key (NEVER commit the real .env file)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Ritual testnet endpoints
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
RITUAL_WS_URL=wss://rpc.ritualfoundation.org/ws
RITUAL_VERIFIER_URL=https://rpc.ritualfoundation.org/api/verify

# Set after deployment
ORACLE_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# Optional: RitualWallet deposit amount in wei (default 0.05 RITUAL)
FUND_AMOUNT=50000000000000000